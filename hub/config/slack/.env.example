# Slack Bot token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack App-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Optional default channel id (e.g. C01234567)
SLACK_DEFAULT_CHANNEL=

# Optional default repository path used by PM mode when creating runs
SLACK_DEFAULT_REPO=

# Optional path to channel->repo map JSON (defaults to hub/config/slack/repo-map.json)
SLACK_REPO_MAP_PATH=

# PM conversational mode enabled by default. Set to false to require `hub <command>` format.
SLACK_PM_MODE=true

# Optional comma-separated allowlist of user IDs (e.g. U111,U222)
SLACK_ALLOWED_USERS=

# Provider auth for PM team execution
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
